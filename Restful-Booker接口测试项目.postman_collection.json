              "});\r",
              "\r",
              "pm.test(\"totalprice 是 199\", function () {\r",
              "    pm.expect(jsonData.totalprice).to.eql(199);\r",
              "});\r",
              "\r",
              "pm.test(\"depositpaid 是 true\", function () {\r",
              "    pm.expect(jsonData.depositpaid).to.eql(true);\r",
              "});\r",
              "\r",
              "pm.test(\"checkin 是 2026-06-20\", function () {\r",
              "    pm.expect(jsonData.bookingdates.checkin).to.eql(\"2026-06-20\");\r",
              "});\r",
              "\r",
              "pm.test(\"checkout 是 2026-06-22\", function () {\r",
              "    pm.expect(jsonData.bookingdates.checkout).to.eql(\"2026-06-22\");\r",
              "});\r",
              "\r",
              "pm.test(\"additionalneeds 是 Breakfast\", function () {\r",
              "    pm.expect(jsonData.additionalneeds).to.eql(\"Breakfast\");\r",
              "});"
            ],
