    {
      "name": "05_更新完整booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    var jsonData = pm.response.json();\r",
              "\r",
              "    pm.test(\"firstname 已更新\", function () {\r",
              "        pm.expect(jsonData.firstname).to.eql(\"YunUpdated\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"lastname 已更新\", function () {\r",
              "        pm.expect(jsonData.lastname).to.eql(\"TesterUpdated\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"totalprice 已更新\", function () {\r",
              "        pm.expect(jsonData.totalprice).to.eql(299);\r",
              "    });\r",
              "\r",
              "    pm.test(\"depositpaid 已更新\", function () {\r",
              "        pm.expect(jsonData.depositpaid).to.eql(false);\r",
              "    });\r",
              "\r",
              "    pm.test(\"checkin 已更新\", function () {\r",
              "        pm.expect(jsonData.bookingdates.checkin).to.eql(\"2026-06-23\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"checkout 已更新\", function () {\r",
              "        pm.expect(jsonData.bookingdates.checkout).to.eql(\"2026-06-25\");\r",
              "    });\r",
              "\r",
              "    pm.test(\"additionalneeds 已更新\", function () {\r",
              "        pm.expect(jsonData.additionalneeds).to.eql(\"Lunch\");\r",
              "    });\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
