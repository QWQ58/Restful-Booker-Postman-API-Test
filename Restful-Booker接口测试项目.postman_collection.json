    {
      "name": "03_创建booking",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "pm.test(\"状态码是 200\",function(){\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"返回 bookingid\",function(){\r",
              "    pm.expect(jsonData).to.have.property(\"bookingid\");\r",
              "});\r",
              "pm.test(\"bookingid 是数字\",function(){\r",
              "    pm.expect(jsonData.bookingid).to.be.a('number');\r",
              "});\r",
              "pm.test(\"firstname 是 Yun\",function(){ \r",
              "    pm.expect(jsonData.booking.firstname).to.equal(\"Yun\");\r",
              "});\r",
              "pm.test(\"lastname 是 Tester\",function(){ \r",
              "    pm.expect(jsonData.booking.lastname).to.equal(\"Tester\");\r",
              "});\r",
              "pm.test(\"totalprice 是 199\",function(){ \r",
              "    pm.expect(jsonData.booking.totalprice).to.equal(199);\r",
              "});\r",
              "pm.test(\"depositpaid 是 true\",function(){ \r",
              "    pm.expect(jsonData.booking.depositpaid).to.equal(true);\r",
              "});\r",
              "pm.test(\"additionalneeds 是 Breakfast\",function(){ \r",
              "    pm.expect(jsonData.booking.additionalneeds).to.equal(\"Breakfast\");\r",
              "});\r",
              "pm.environment.set(\"bookingid\", jsonData.bookingid);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"firstname\": \"Yun\",\r\n  \"lastname\": \"Tester\",\r\n  \"totalprice\": 199,\r\n  \"depositpaid\": true,\r\n  \"bookingdates\": {\r\n    \"checkin\": \"2026-06-20\",\r\n    \"checkout\": \"2026-06-22\"\r\n  },\r\n  \"additionalneeds\": \"Breakfast\"\r\n}",
